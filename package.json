{
  "name": "al-1s",
  "version": "1.0.0",
  "description": "AI Girlfriend Desktop Application",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "electron .",
    "electron:build": "electron-builder",
    "start": "npm run electron:compile && concurrently -k \"npm run dev -- --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development npm run electron:dev\""
  },
  "keywords": [],
